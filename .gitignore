## .gitignore for tree-manager-net — Visual Studio + dotnet + Rider + project-specific
## Base: github/gitignore VisualStudio.gitignore + Dotnet.gitignore

# User-specific Visual Studio files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/
*.pidb
*.svclog
*.scc

# Rider
.idea/
*.sln.iml
_ReSharper*/
*.[Rr]eSharper
*.DotSettings.user

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# dotenv environment variables file
.env

# Secrets — never commit (sprint-16 Gmail app-password)
*.user.json

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
test-results/
coverage/
*.trx
*.coverage
*.coveragexml

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# MSBuild Binary and Structured Log
*.binlog

# Others
~$*
*~
CodeCoverage/

# VS Code
.vscode/

# Windows image file caches
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
