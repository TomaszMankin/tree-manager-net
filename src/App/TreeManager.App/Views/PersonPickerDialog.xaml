<Window x:Class="TreeManager.App.Views.PersonPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wybierz osobę"
        Height="420" Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="SelectButton" Content="Wybierz" Width="90" Margin="0,0,8,0"
                    IsDefault="True"
                    Click="SelectButton_Click"/>
            <Button Content="Anuluj" Width="90"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>

        <TextBox DockPanel.Dock="Top"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,8"
                 Padding="6,4"
                 FontSize="14"/>

        <ListBox x:Name="PeopleList"
                 ItemsSource="{Binding FilteredPeople}"
                 SelectedItem="{Binding SelectedPerson, Mode=TwoWay}"
                 DisplayMemberPath="DisplayName"
                 FontSize="13"/>

    </DockPanel>
</Window>
