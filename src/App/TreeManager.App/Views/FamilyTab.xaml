<UserControl x:Class="TreeManager.App.Views.FamilyTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:TreeManager.App.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Column="0" Grid.Row="0" Header="Rodzice" Margin="0,0,8,8" Padding="8">
                <views:MultiPersonPickerControl DataContext="{Binding Parents}"/>
            </GroupBox>

            <GroupBox Grid.Column="1" Grid.Row="0" Header="Małżonkowie" Margin="8,0,0,8" Padding="8">
                <views:MultiPersonPickerControl DataContext="{Binding Spouses}"/>
            </GroupBox>

            <GroupBox Grid.Column="0" Grid.Row="1" Header="Dzieci" Margin="0,0,8,0" Padding="8">
                <views:MultiPersonPickerControl DataContext="{Binding Children}"/>
            </GroupBox>

            <GroupBox Grid.Column="1" Grid.Row="1" Header="Rodzeństwo" Margin="8,0,0,0" Padding="8">
                <views:MultiPersonPickerControl DataContext="{Binding Siblings}"/>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>
