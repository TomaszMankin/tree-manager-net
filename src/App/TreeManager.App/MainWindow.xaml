<Window x:Class="TreeManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TreeManager.App.ViewModels"
        xmlns:views="clr-namespace:TreeManager.App.Views"
        Title="TreeManager"
        Height="700" Width="940" MinHeight="600" MinWidth="800"
        FontFamily="Segoe UI">
    <DockPanel>

        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="#1565C0" Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="TreeManager" FontSize="22" Foreground="White"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Dodaj osobę"
                            Command="{Binding SwitchModeCommand}"
                            CommandParameter="{x:Static vm:AppMode.Add}"
                            Margin="4,0" Padding="14,8"/>
                    <Button Content="Edytuj drzewo"
                            Command="{Binding SwitchModeCommand}"
                            CommandParameter="{x:Static vm:AppMode.EditTree}"
                            Margin="4,0" Padding="14,8"/>
                    <Button Content="Edytuj szkic"
                            Command="{Binding SwitchModeCommand}"
                            CommandParameter="{x:Static vm:AppMode.EditDraft}"
                            Margin="4,0" Padding="14,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Mode-tinted content area -->
        <Grid Background="{Binding CurrentMode, Converter={StaticResource ModeToBackgroundBrushConverter}}">
            <TabControl Margin="0" Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
                <TabItem Header="1.  Dane osoby">
                    <views:PersonDataTab DataContext="{Binding Person}"/>
                </TabItem>
                <TabItem Header="2.  Daty">
                    <views:DatesTab DataContext="{Binding Dates}"/>
                </TabItem>
                <TabItem Header="3.  Rodzina">
                    <TextBlock Text="Zawartość zakładki — sprint-07+" Margin="32,24"/>
                </TabItem>
                <TabItem Header="4.  Notatki">
                    <TextBlock Text="Zawartość zakładki — sprint-10+" Margin="32,24"/>
                </TabItem>
            </TabControl>
        </Grid>

    </DockPanel>
</Window>
